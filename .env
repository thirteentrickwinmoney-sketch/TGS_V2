# ─────────────────────────────────────────────────────────────────────────────
# TGS Payment Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — only commit .env.example
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Your backend's own public URL (Railway/Render gives you one automatically).
# Used as fallback if the app doesn't send success_url / cancel_url.
# Example: https://tgs-backend-production.up.railway.app
BACKEND_URL=https://YOUR_RAILWAY_OR_RENDER_URL

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price IDs — create in: Stripe Dashboard → Products → Add product
# Monthly subscription (recurring, interval=month)
STRIPE_PRICE_MONTHLY=price_YOUR_MONTHLY_PRICE_ID

# Quarterly subscription (recurring, interval=month, interval_count=3)
STRIPE_PRICE_QUARTERLY=price_YOUR_QUARTERLY_PRICE_ID

# Annual subscription (recurring, interval=year)
STRIPE_PRICE_ANNUAL=price_YOUR_ANNUAL_PRICE_ID

# Lifetime one-time payment (one_time, not recurring)
STRIPE_PRICE_LIFETIME=price_YOUR_LIFETIME_PRICE_ID

# ── Google Play Developer API ────────────────────────────────────────────────
# Steps:
#   1. Google Play Console → Setup → API access
#   2. Link to a Google Cloud project
#   3. Create Service Account with "Financial data" viewer role
#   4. Download JSON key → paste entire JSON as single line below
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Your app's package name (must match Play Console exactly)
ANDROID_PACKAGE_NAME=com.lihov.plh

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# Steps:
#   1. Firebase Console → Project settings → Service accounts
#   2. Click "Generate new private key" → download JSON
#   3. Paste entire JSON as single line below
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed web origins (landing page, etc.)
# Android WebView sends no Origin header so it's always allowed regardless.
ALLOWED_ORIGINS=https://tradergodapp.com,https://www.tradergodapp.com
